---
layout: base.njk
---

<!-- ARTICLE HEADER -->
<div class="article-header">
  <div class="wrap">
    <div style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:24px;">
      <a href="/blog/" style="color:var(--muted);text-decoration:underline;text-underline-offset:3px;">Blog</a>
      <span style="margin:0 8px;">→</span>
      <span>{{ tag | capitalize }}</span>
    </div>
    <div class="article-meta">
      <span class="post-tag tag-{{ tag }}">{{ tag | capitalize }}</span>
      <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);">{{ page.date | postDate }}</span>
      {% if readtime %}<span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);">{{ readtime }} mnt baca</span>{% endif %}
    </div>
    <h1 class="article-title">{{ title | safe }}</h1>
    {% if excerpt %}<p class="article-deck">{{ excerpt }}</p>{% endif %}
  </div>
</div>

<!-- YOUTUBE EMBED (jika artikel punya versi video) -->
{% if youtube_url %}
<div class="wrap">
  <div class="yt-embed-wrap">
    <div class="yt-embed-label">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--accent-1)" style="flex-shrink:0;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      Tonton versi video artikel ini di YouTube
    </div>
    <div class="yt-embed-frame">
      <iframe
        src="{{ youtube_url | replace('watch?v=', 'embed/') | replace('youtu.be/', 'www.youtube.com/embed/') }}"
        title="{{ title }}"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen>
      </iframe>
    </div>
  </div>
</div>
{% endif %}

<!-- ARTICLE BODY -->
<div class="wrap">
  <div class="article-body">
    {{ content | safe }}
  </div>
</div>

<!-- BACK TO BLOG -->
<div class="wrap" style="padding-bottom: 64px; border-top: 1px solid var(--ink); padding-top: 40px; margin-top: 0;">
  <a href="/blog/" class="btn btn-outline">← Kembali ke Blog</a>
</div>
